# Stripe secret key — find this in the Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY

# The URL of your frontend app (used for Stripe redirect URLs)
DOMAIN=http://localhost:3000

# Stripe webhook signing secret — get this by running:
#   stripe listen --forward-to localhost:4242/webhook
WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SIGNING_SECRET
